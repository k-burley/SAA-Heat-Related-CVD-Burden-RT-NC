geom_histogram(aes(x=pct_hh_below_pl_cbg), fill="blue") +
ggtitle("CBG")
pov_zcta <- ggplot(zcta_cbg) +
geom_histogram(aes(x=pct_hh_below_pl_zcta), fill="green") +
ggtitle("ZCTA")
ggarrange(pov_cbg, pov_zcta)
zcta <- zcta_cbg %>%
distinct(ZCTA5, pct_hh_below_pl_zcta, pct_w_bach_zcta)
