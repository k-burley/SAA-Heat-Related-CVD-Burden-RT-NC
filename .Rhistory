geom_histogram(aes(x=pct_w_bach_zcta), fill="green") +
ggtitle("ZCTA")
ggarrange(educ_cbg, educ_zcta)
cor(zcta_cbg$pct_w_bach_cbg, zcta_cbg$pct_w_bach_zcta, method = "pearson", use="complete.obs")
cor(zcta_cbg$pct_hh_below_pl_cbg, zcta_cbg$pct_hh_below_pl_zcta, method = "pearson", use="complete.obs")
