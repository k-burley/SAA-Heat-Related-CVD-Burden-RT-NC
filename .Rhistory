geom_histogram(aes(x=pct_hh_below_pl_zcta), fill="green") +
ggtitle("ZCTA")
ggarrange(pov_cbg, pov_zcta)
cor(zcta_cbg$pct_hh_below_pl_cbg, zcta_cbg$pct_hh_below_pl_zcta, method = "pearson", use="complete.obs")
