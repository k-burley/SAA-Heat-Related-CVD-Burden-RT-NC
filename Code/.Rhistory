rural_pop = U7I003) # %>%
reg_data <- cbg_comp_sf_plot %>%
select(GEOID, pop_count, tot_an_rate, tot_cvd_rate) %>%
left_join(acs_cbg, by="GEOID") %>%
rename(degree_bach = AMRZE022,
degree_mast = AMRZE023,
degree_prof = AMRZE024,
degree_doct = AMRZE025,
tot_pop_25_pl = AMRZE001,
hh_below_pl = AMR5E002,
tot_hh = AMR5E001,
tot_hu =AMUFE001,
oo_hu = AMUFE002,
ro_hu = AMUFE003,
tot_pop = AMP3E001,
white_alone = AMP3E003,
tot_pop2 = U7I001,
urban_pop = U7I002,
rural_pop = U7I003) %>%
mutate(pct_w_bach = ((degree_bach+degree_mast+degree_prof+degree_doct)/tot_pop_25_pl)*100,
pct_hh_below_pl = (hh_below_pl/tot_hh)*100,
pct_hu_rented = (ro_hu/tot_hu)*100,
pct_nonwhite = ((tot_pop-white_alone)/tot_pop)*100,
pct_rural_pop = (rural_pop/tot_pop2)*100)
View(reg_data)
View(reg_data)
View(cbg_comp_sf_plot)
