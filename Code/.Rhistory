cluster_map_gg <- ggplot(cluster) +
geom_sf(aes(fill=risk_group)) +
scale_fill_manual(name = "Risk Group",
breaks = c("Low Risk", "Health Driven Risk", "Heat Driven Risk", "Dual Channel Risk"),
values = c("#8AE3FE", "#00A08A","#fdae61","#F21A00")) +
# values=c(lighten(pal2[5],0.5), pal2[2], "#fdae61", pal[5])))
geom_point(data = coordinates, aes(Longitude, Latitude), color="black") +
geom_text(data = coordinates, aes(Longitude, Latitude, label = Name),
vjust = 1.2, hjust = 1.2, color= "black", size=5) +
theme_bw() +
theme(axis.text = element_blank(),
legend.position = "none",
panel.grid=element_blank(),
legend.text=element_text(size=16),
plot.background = element_blank(),
panel.border = element_blank(),
axis.title.x = element_blank(),
axis.title.y = element_blank(),
axis.text.x = element_blank(),
axis.text.y = element_blank(),
axis.ticks = element_blank())
cluster_map_gg
plot_grid(cluster_map_gg, radar_plot, ncol = 2, labels = c("", ""), rel_widths = c(1, 1.5))
radar_plot <- ~{
par(mfrow = c(2, 2), mar = c(1, 0.2, 1, 0.2))
radarchart(lowrisk_data,
pcol = "#8AE3FE", pfcol = scales::alpha("#8AE3FE", 0.5),
plwd = 2, plty = 1, title = "Low Risk")
radarchart(healthdriven_data,
pcol = "#00A08A", pfcol = scales::alpha("#00A08A", 0.5),
plwd = 2, plty = 1, title = "Health Driven Risk")
radarchart(heatdriven_data,
pcol = "#fdae61", pfcol = scales::alpha("#fdae61", 0.5),
plwd = 2, plty = 1, title = "Heat Driven Risk")
radarchart(dualchannel_data,
pcol = "#F21A00", pfcol = scales::alpha("#F21A00", 0.5),
plwd = 2, plty = 1, title = "Dual Channel Risk")
# dev.off()
}
radar_plot
plot_grid(cluster_map_gg, radar_plot, ncol = 2, labels = c("", ""), rel_widths = c(1, 1.5))
cluster_with_radar <- plot_grid(cluster_map_gg, radar_plot, ncol = 2, labels = c("", ""), rel_widths = c(1, 1.5))
save_plot("../Data/Figures/Fig4_Cluster.png", cluster_with_radar, height=7, width=14, units="in")
?save_plot
save_plot("../Data/Figures/Fig4_Cluster.png", cluster_with_radar, base_height=7, base_width=14, units="in")
